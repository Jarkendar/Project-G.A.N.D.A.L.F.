# G.A.N.D.A.L.F. environment configuration
# Copy this file to .claude/gandalf.env and set the values.
# .claude/gandalf.env is gitignored — never commit it.

# Path to the brain/ knowledge repository.
# Relative to the root of this project, or absolute.
# Example (sibling directory): ../brain
# Example (absolute): /home/user/repos/brain
BRAIN_PATH=../brain

# Strava API (OAuth) — create an app at https://www.strava.com/settings/api
# (Authorization Callback Domain = localhost). These are SECRETS.
# Real values go only in .claude/gandalf.env (gitignored) — never commit them.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Optional: pre-seed tokens to skip the browser bootstrap. Normally leave empty —
# the server bootstraps OAuth and manages these in ~/.config/strava-mcp/config.json.
# STRAVA_ACCESS_TOKEN=
# STRAVA_REFRESH_TOKEN=
